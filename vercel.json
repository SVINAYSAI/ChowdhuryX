{
  "version": 2,
  "name": "chowdhuryx-website",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/about",
      "dest": "/about.html"
    },
    {
      "src": "/services",
      "dest": "/services.html"
    },
    {
      "src": "/process",
      "dest": "/process.html"
    },
    {
      "src": "/contact",
      "dest": "/contact.html"
    }
  ]
}
